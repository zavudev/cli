#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/zavudev/sdk-go,github.com/stainless-sdks/zavudev-go"

REPLACEMENT="${1:-"../zavudev-go"}"
echo "==> Replacing Go SDK with $REPLACEMENT"
go mod edit -replace github.com/zavudev/sdk-go="$REPLACEMENT"
go mod tidy -e
